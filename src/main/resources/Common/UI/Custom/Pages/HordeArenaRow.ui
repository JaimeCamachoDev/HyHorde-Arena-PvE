$C = "../Common.ui";

@ArenaRowHitboxStyle = TextButtonStyle(
  Default: (Background: #000000(0), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Hovered: (Background: #ffffff(0.07), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Pressed: (Background: #ffffff(0.12), LabelStyle: (FontSize: 1, TextColor: #000000(0)))
);

Group #HordeArenaRow {
  Anchor: (Left: 0, Right: 0, Height: 62, Bottom: 8);
  Background: #2f4c6f(0.96);

  Panel #ArenaAccent {
    Anchor: (Left: 0, Top: 0, Width: 6, Height: 62);
    Background: #e0b84a;
  }

  TextButton #ArenaOpenButton {
    Anchor: (Left: 0, Top: 0, Right: 0, Height: 62);
    Text: "";
    Style: @ArenaRowHitboxStyle;
  }

  Panel #ArenaIconBack {
    Anchor: (Left: 12, Top: 6, Width: 50, Height: 50);
    Background: #223854(0.95);
  }

  ItemIcon #ArenaIcon {
    Anchor: (Left: 12, Top: 6, Width: 50, Height: 50);
  }

  TextButton #ArenaIconButton {
    Anchor: (Left: 12, Top: 6, Width: 50, Height: 50);
    Text: "";
    Visible: false;
    Style: @ArenaRowHitboxStyle;
  }

  Label #ArenaName {
    Anchor: (Left: 76, Top: 10, Right: 64, Height: 22);
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ecf4ff, RenderBold: true, VerticalAlignment: Center);
  }

  Label #ArenaCoords {
    Anchor: (Left: 76, Top: 33, Right: 64, Height: 18);
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #b8cbe5, VerticalAlignment: Center);
  }

  TextButton #ArenaDeleteButton {
    Anchor: (Right: 8, Top: 11, Width: 40, Height: 40);
    Text: "X";
    Style: $C.@CancelTextButtonStyle;
  }
}
