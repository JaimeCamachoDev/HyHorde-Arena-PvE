$C = "../Common.ui";

@OfficialDropdownBoxStyle = DropdownBoxStyle(
  ...$C.@DefaultDropdownBoxStyle,
  LabelStyle: (
    ...$C.@DefaultDropdownBoxLabelStyle,
    FontSize: 15,
    RenderBold: true
  ),
  EntryLabelStyle: (
    ...$C.@DefaultDropdownBoxEntryLabelStyle,
    FontSize: 15
  ),
  SelectedEntryLabelStyle: (
    ...$C.@DefaultDropdownBoxEntryLabelStyle,
    FontSize: 15,
    RenderBold: true
  ),
  PanelAlign: Bottom
);

