Group {
  Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);

  Panel #Overlay {
    Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);
    Background: #000000(0.42);
  }

  Panel #Card {
    Anchor: (Left: 460, Top: 90, Width: 1000, Height: 900);
    Background: #142131;
  }

  Panel #Header {
    Anchor: (Left: 460, Top: 90, Width: 1000, Height: 96);
    Background: #1f3249;
  }

  Label #TitleLabel {
    Anchor: (Left: 492, Top: 112, Width: 520, Height: 34);
    Text: "Horda PVE Config";
    Style: (FontSize: 29, TextColor: #f1f7ff, RenderBold: true, VerticalAlignment: Center);
  }

  Label #SubTitleLabel {
    Anchor: (Left: 492, Top: 146, Width: 740, Height: 24);
    Text: "Config minima: centro, dificultad, enemigo, idioma y recompensa";
    Style: (FontSize: 14, TextColor: #b8cadf, VerticalAlignment: Center);
  }

  Label #SpawnStateLabel {
    Anchor: (Left: 492, Top: 206, Width: 936, Height: 24);
    Text: "";
    Style: (FontSize: 13, TextColor: #cfe0f3, RenderBold: true, VerticalAlignment: Center);
  }

  Label #SpawnLabel {
    Anchor: (Left: 492, Top: 240, Width: 170, Height: 28);
    Text: "Centro (X Y Z)";
    Style: (FontSize: 15, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #SpawnX {
    Anchor: (Left: 668, Top: 238, Width: 118, Height: 34);
    Value: "0.00";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  TextField #SpawnY {
    Anchor: (Left: 792, Top: 238, Width: 118, Height: 34);
    Value: "64.00";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  TextField #SpawnZ {
    Anchor: (Left: 916, Top: 238, Width: 118, Height: 34);
    Value: "0.00";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  TextButton #SetSpawnButton {
    Anchor: (Left: 1044, Top: 238, Width: 384, Height: 34);
    Text: "Usar mi posicion actual";
    Style: TextButtonStyle(
      Default: (Background: #2e4565, LabelStyle: (FontSize: 13, TextColor: #f3f7ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #3a5b84, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4a6e9b, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  Label #RadiusLabel {
    Anchor: (Left: 492, Top: 284, Width: 170, Height: 28);
    Text: "Radio min / max";
    Style: (FontSize: 15, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #MinRadius {
    Anchor: (Left: 668, Top: 282, Width: 182, Height: 34);
    Value: "5.00";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  TextField #MaxRadius {
    Anchor: (Left: 856, Top: 282, Width: 178, Height: 34);
    Value: "12.00";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #RoundLabel {
    Anchor: (Left: 492, Top: 338, Width: 150, Height: 24);
    Text: "Rondas";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #Rounds {
    Anchor: (Left: 492, Top: 362, Width: 136, Height: 34);
    Value: "5";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #BaseEnemiesLabel {
    Anchor: (Left: 642, Top: 338, Width: 160, Height: 24);
    Text: "Base ronda";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #BaseEnemies {
    Anchor: (Left: 642, Top: 362, Width: 136, Height: 34);
    Value: "8";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #EnemiesPerRoundLabel {
    Anchor: (Left: 792, Top: 338, Width: 180, Height: 24);
    Text: "Inc. por ronda";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #EnemiesPerRound {
    Anchor: (Left: 792, Top: 362, Width: 136, Height: 34);
    Value: "2";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #WaveDelayLabel {
    Anchor: (Left: 942, Top: 338, Width: 180, Height: 24);
    Text: "Delay (s)";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #WaveDelay {
    Anchor: (Left: 942, Top: 362, Width: 136, Height: 34);
    Value: "8";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #PlayerMultiplierLabel {
    Anchor: (Left: 1092, Top: 338, Width: 170, Height: 24);
    Text: "Jugadores (x)";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #PlayerMultiplier {
    Anchor: (Left: 1092, Top: 362, Width: 136, Height: 34);
    Value: "1";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #RoleLabel {
    Anchor: (Left: 492, Top: 422, Width: 200, Height: 28);
    Text: "Categoria de horda";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextButton #EnemyTypePrevButton {
    Anchor: (Left: 668, Top: 422, Width: 46, Height: 34);
    Text: "<";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextField #EnemyType {
    Anchor: (Left: 720, Top: 422, Width: 242, Height: 34);
    Value: "undead";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  TextButton #EnemyTypeNextButton {
    Anchor: (Left: 968, Top: 422, Width: 46, Height: 34);
    Text: ">";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextButton #RolesButton {
    Anchor: (Left: 1020, Top: 422, Width: 152, Height: 34);
    Text: "Ver categorias";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 13, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  Label #LanguageLabel {
    Anchor: (Left: 980, Top: 496, Width: 176, Height: 28);
    Text: "Idioma de interfaz";
    Style: (FontSize: 14, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextButton #LanguagePrevButton {
    Anchor: (Left: 1160, Top: 494, Width: 38, Height: 34);
    Text: "<";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextField #Language {
    Anchor: (Left: 1204, Top: 494, Width: 188, Height: 34);
    Value: "Espanol (es)";
    Style: (FontSize: 13, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  TextButton #LanguageNextButton {
    Anchor: (Left: 1396, Top: 494, Width: 34, Height: 34);
    Text: ">";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  Label #RoleHelpLabel {
    Anchor: (Left: 668, Top: 458, Width: 760, Height: 22);
    Text: "Usa < > para cambiar categoria";
    Style: (FontSize: 12, TextColor: #9cb4d1, VerticalAlignment: Center);
  }

  Label #RewardEveryRoundsLabel {
    Anchor: (Left: 492, Top: 496, Width: 176, Height: 28);
    Text: "Recompensa por ronda(s)";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #RewardEveryRounds {
    Anchor: (Left: 668, Top: 494, Width: 136, Height: 34);
    Value: "2";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #RewardCommandsLabel {
    Anchor: (Left: 492, Top: 544, Width: 170, Height: 28);
    Text: "Item recompensa";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextButton #RewardItemPrevButton {
    Anchor: (Left: 668, Top: 544, Width: 46, Height: 34);
    Text: "<";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextField #RewardItemId {
    Anchor: (Left: 720, Top: 544, Width: 388, Height: 34);
    Value: "";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  TextButton #RewardItemNextButton {
    Anchor: (Left: 1114, Top: 544, Width: 46, Height: 34);
    Text: ">";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextButton #RewardTypesButton {
    Anchor: (Left: 1166, Top: 544, Width: 120, Height: 34);
    Text: "Ver loot";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 13, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  Label #RewardCommandsHelpLabel {
    Anchor: (Left: 668, Top: 580, Width: 620, Height: 22);
    Text: "Tip: la primera sugerencia es un item testado para este modpack.";
    Style: (FontSize: 12, TextColor: #9cb4d1, VerticalAlignment: Center);
  }

  Label #RewardItemQuantityLabel {
    Anchor: (Left: 1294, Top: 548, Width: 80, Height: 22);
    Text: "Cant.";
    Style: (FontSize: 12, TextColor: #9cb4d1, VerticalAlignment: Center);
  }

  TextField #RewardItemQuantity {
    Anchor: (Left: 1376, Top: 544, Width: 52, Height: 34);
    Value: "1";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #StatusTitleLabel {
    Anchor: (Left: 492, Top: 620, Width: 220, Height: 26);
    Text: "Estado actual";
    Style: (FontSize: 16, TextColor: #f4f7fc, RenderBold: true, VerticalAlignment: Center);
  }

  Panel #StatusPanel {
    Anchor: (Left: 492, Top: 648, Width: 936, Height: 130);
    Background: #0f1825;
  }

  Label #StatusLabel {
    Anchor: (Left: 506, Top: 662, Width: 908, Height: 102);
    Text: "";
    Style: (FontSize: 13, TextColor: #d1e0f3, VerticalAlignment: Center);
  }

  TextButton #SaveButton {
    Anchor: (Left: 492, Top: 810, Width: 220, Height: 44);
    Text: "Guardar config";
    Style: TextButtonStyle(
      Default: (Background: #265f3f, LabelStyle: (FontSize: 15, TextColor: #f4fff9, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #2f7850, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #1d4e33, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextButton #StartButton {
    Anchor: (Left: 728, Top: 810, Width: 200, Height: 44);
    Text: "Iniciar horda";
    Style: TextButtonStyle(
      Default: (Background: #1c7a4a, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #259a5d, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #165f3a, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextButton #StopButton {
    Anchor: (Left: 728, Top: 810, Width: 200, Height: 44);
    Text: "Detener horda";
    Visible: false;
    Style: TextButtonStyle(
      Default: (Background: #7a2c2c, LabelStyle: (FontSize: 15, TextColor: #fff1f1, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #984040, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #5f2222, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextButton #CloseButton {
    Anchor: (Left: 1246, Top: 810, Width: 182, Height: 44);
    Text: "Cerrar";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 15, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
