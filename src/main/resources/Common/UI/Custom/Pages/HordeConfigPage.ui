  Label #RewardCategoryLabel {
    Anchor: (Left: 456, Top: 276, Width: 200, Height: 28);
    Text: "Categoria recompensa";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
