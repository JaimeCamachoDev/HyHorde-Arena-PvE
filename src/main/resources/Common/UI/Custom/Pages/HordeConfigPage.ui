    Style: (FontSize: 13, TextColor: #d6e3f2, VerticalAlignment: Center);
  }

  Label #PlayersListTitle {
    Anchor: (Left: 456, Top: 264, Width: 560, Height: 30);
    Text: "Jugadores en area";
    Style: (FontSize: 18, TextColor: #f4f7fc, RenderBold: true, VerticalAlignment: Center);
  }

  Label #PlayersCountLabel {
    Anchor: (Left: 1048, Top: 268, Width: 94, Height: 22);
    Text: "Detectados";
