$C = "../Common.ui";

Group {
  Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);

  $C.@PageOverlay #Overlay {
    Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);
  }

  Panel #Card {
    Anchor: (Left: 430, Top: 72, Width: 1060, Height: 930);
    Background: #142131;
  }

  Panel #Header {
    Anchor: (Left: 430, Top: 72, Width: 1060, Height: 108);
    Background: #1f3249;
  }

  Label #TitleLabel {
    Anchor: (Left: 456, Top: 94, Width: 560, Height: 36);
    Text: "Horda PVE Config";
    Style: (FontSize: 31, TextColor: #f1f7ff, RenderBold: true, VerticalAlignment: Center);
  }

  Label #SubTitleLabel {
    Anchor: (Left: 456, Top: 130, Width: 760, Height: 24);
    Text: "";
    Style: (FontSize: 14, TextColor: #b8cadf, VerticalAlignment: Center);
  }

  TextButton #TabGeneralButton {
    Anchor: (Left: 954, Top: 94, Width: 80, Height: 32);
    Text: "General";
    Style: $C.@SmallSecondaryTextButtonStyle;
    Padding: (Horizontal: 8);
  }

  TextButton #TabHordeButton {
    Anchor: (Left: 1038, Top: 94, Width: 80, Height: 32);
    Text: "Horda";
    Style: $C.@SmallSecondaryTextButtonStyle;
    Padding: (Horizontal: 8);
  }

  TextButton #TabPlayersButton {
    Anchor: (Left: 1122, Top: 94, Width: 86, Height: 32);
    Text: "Jugadores";
    Style: $C.@SmallSecondaryTextButtonStyle;
    Padding: (Horizontal: 8);
  }

  TextButton #TabSoundsButton {
    Anchor: (Left: 1212, Top: 94, Width: 80, Height: 32);
    Text: "Sonidos";
    Style: $C.@SmallSecondaryTextButtonStyle;
    Padding: (Horizontal: 8);
  }

  TextButton #TabRewardsButton {
    Anchor: (Left: 1296, Top: 94, Width: 110, Height: 32);
    Text: "Recompensas";
    Style: $C.@SmallSecondaryTextButtonStyle;
    Padding: (Horizontal: 8);
  }

  TextButton #TabHelpButton {
    Anchor: (Left: 1410, Top: 94, Width: 80, Height: 32);
    Text: "Ayuda";
    Style: $C.@SmallSecondaryTextButtonStyle;
    Padding: (Horizontal: 8);
  }

  Label #TabHintLabel {
    Anchor: (Left: 954, Top: 132, Width: 536, Height: 22);
    Text: "";
    Style: (FontSize: 11, TextColor: #a8bdd8, VerticalAlignment: Center);
  }

  Label #SpawnStateLabel {
    Anchor: (Left: 456, Top: 194, Width: 1008, Height: 24);
    Text: "";
    Style: (FontSize: 13, TextColor: #cfe0f3, RenderBold: true, VerticalAlignment: Center);
  }

  Label #SpawnLabel {
    Anchor: (Left: 456, Top: 232, Width: 180, Height: 28);
    Text: "Centro (X Y Z)";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@TextField #SpawnX {
    @Anchor = (Left: 642, Top: 230, Width: 124);
    Value: "0.00";
  }

  $C.@TextField #SpawnY {
    @Anchor = (Left: 772, Top: 230, Width: 124);
    Value: "64.00";
  }

  $C.@TextField #SpawnZ {
    @Anchor = (Left: 902, Top: 230, Width: 124);
    Value: "0.00";
  }

  TextButton #SetSpawnButton {
    Anchor: (Left: 1034, Top: 230, Width: 430, Height: 34);
    Text: "Usar mi posicion actual";
    Style: $C.@SecondaryTextButtonStyle;
  }

  Label #RadiusLabel {
    Anchor: (Left: 456, Top: 320, Width: 180, Height: 28);
    Text: "Radio min / max";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #MinRadius {
    @Anchor = (Left: 642, Top: 318, Width: 188);
    Value: 5.0;
    Min: 1.0;
    Max: 128.0;
    Step: 0.5;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  $C.@SliderNumberField #MaxRadius {
    @Anchor = (Left: 836, Top: 318, Width: 190);
    Value: 12.0;
    Min: 1.0;
    Max: 128.0;
    Step: 0.5;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #ArenaJoinRadiusLabel {
    Anchor: (Left: 456, Top: 274, Width: 180, Height: 28);
    Text: "Radio jugadores";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #ArenaJoinRadius {
    @Anchor = (Left: 642, Top: 272, Width: 188);
    Value: 32.0;
    Min: 4.0;
    Max: 512.0;
    Step: 1.0;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  TextButton #ReloadModButton {
    Anchor: (Left: 706, Top: 844, Width: 170, Height: 46);
    Text: "Recargar config";
    Style: $C.@TertiaryTextButtonStyle;
  }

  Label #RoundLabel {
    Anchor: (Left: 456, Top: 232, Width: 320, Height: 24);
    Text: "Rondas";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #Rounds {
    @Anchor = (Left: 456, Top: 258, Width: 320);
    Value: 5;
    Min: 1;
    Max: 200;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #BaseEnemiesLabel {
    Anchor: (Left: 806, Top: 232, Width: 320, Height: 24);
    Text: "Base ronda";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #BaseEnemies {
    @Anchor = (Left: 806, Top: 258, Width: 320);
    Value: 8;
    Min: 1;
    Max: 400;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #EnemiesPerRoundLabel {
    Anchor: (Left: 456, Top: 302, Width: 320, Height: 24);
    Text: "Inc. por ronda";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #EnemiesPerRound {
    @Anchor = (Left: 456, Top: 328, Width: 320);
    Value: 2;
    Min: 0;
    Max: 400;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #WaveDelayLabel {
    Anchor: (Left: 806, Top: 302, Width: 320, Height: 24);
    Text: "Delay (s)";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #WaveDelay {
    @Anchor = (Left: 806, Top: 328, Width: 320);
    Value: 8;
    Min: 0;
    Max: 300;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #PlayerMultiplierLabel {
    Anchor: (Left: 1096, Top: 232, Width: 170, Height: 24);
    Text: "Jugadores (x)";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
