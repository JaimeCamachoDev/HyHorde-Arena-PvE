    Anchor: (Left: 1068, Top: 936, Width: 192, Height: 46);
    Text: "Pasar ronda";
    Visible: false;
    Style: $C.@TertiaryTextButtonStyle;
  }

  TextButton #HordeCloseButton {
    Anchor: (Left: 1272, Top: 936, Width: 192, Height: 46);
    Text: "Cerrar";
    Style: $C.@CancelTextButtonStyle;
  }
}
