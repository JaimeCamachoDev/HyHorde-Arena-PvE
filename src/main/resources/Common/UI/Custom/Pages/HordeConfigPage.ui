$C = "../Common.ui";

Group {
  Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);

  $C.@PageOverlay #Overlay {
    Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);
  }

  Panel #Card {
    Anchor: (Left: 430, Top: 72, Width: 1060, Height: 930);
    Background: #142131;
  }

  Panel #Header {
    Anchor: (Left: 430, Top: 72, Width: 1060, Height: 116);
    Background: #213650;
  }

  Panel #CategoryBar {
    Anchor: (Left: 858, Top: 84, Width: 624, Height: 52);
    Background: #122239;
  }

  Panel #CategoryLine {
    Anchor: (Left: 456, Top: 144, Width: 1008, Height: 8);
    Background: #2a4565;
  }

  Label #TitleLabel {
    Anchor: (Left: 456, Top: 92, Width: 470, Height: 40);
    Text: "Horda PVE Config";
    Style: (FontSize: 30, TextColor: #f1f7ff, RenderBold: true, VerticalAlignment: Center);
  }

  Label #SubTitleLabel {
    Anchor: (Left: 456, Top: 130, Width: 760, Height: 24);
    Text: "";
    Visible: false;
    Style: (FontSize: 14, TextColor: #b8cadf, VerticalAlignment: Center);
  }

  TextButton #TabGeneralButton {
    Anchor: (Left: 862, Top: 92, Width: 100, Height: 36);
    Text: "General";
    Style: TextButtonStyle(
      Default: (Background: #1a2f48, LabelStyle: (FontSize: 13, TextColor: #dce8f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #284768, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #3c648e, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
    Padding: (Horizontal: 8);
  }

  TextButton #TabHordeButton {
    Anchor: (Left: 966, Top: 92, Width: 100, Height: 36);
    Text: "Horda";
    Style: TextButtonStyle(
      Default: (Background: #1a2f48, LabelStyle: (FontSize: 13, TextColor: #dce8f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #284768, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #3c648e, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
    Padding: (Horizontal: 8);
  }

  TextButton #TabPlayersButton {
    Anchor: (Left: 1070, Top: 92, Width: 100, Height: 36);
    Text: "Jugadores";
    Style: TextButtonStyle(
      Default: (Background: #1a2f48, LabelStyle: (FontSize: 13, TextColor: #dce8f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #284768, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #3c648e, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
    Padding: (Horizontal: 8);
  }

  TextButton #TabSoundsButton {
    Anchor: (Left: 1174, Top: 92, Width: 100, Height: 36);
    Text: "Sonidos";
    Style: TextButtonStyle(
      Default: (Background: #1a2f48, LabelStyle: (FontSize: 13, TextColor: #dce8f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #284768, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #3c648e, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
    Padding: (Horizontal: 8);
  }

  TextButton #TabRewardsButton {
    Anchor: (Left: 1278, Top: 92, Width: 100, Height: 36);
    Text: "Recompensas";
    Style: TextButtonStyle(
      Default: (Background: #1a2f48, LabelStyle: (FontSize: 13, TextColor: #dce8f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #284768, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #3c648e, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
    Padding: (Horizontal: 8);
  }

  TextButton #TabHelpButton {
    Anchor: (Left: 1382, Top: 92, Width: 100, Height: 36);
    Text: "Ayuda";
    Style: TextButtonStyle(
      Default: (Background: #1a2f48, LabelStyle: (FontSize: 13, TextColor: #dce8f8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #284768, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #3c648e, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
    Padding: (Horizontal: 8);
  }

  Label #TabHintLabel {
    Anchor: (Left: 954, Top: 132, Width: 536, Height: 22);
    Text: "";
    Visible: false;
    Style: (FontSize: 11, TextColor: #a8bdd8, VerticalAlignment: Center);
  }

  Label #SpawnStateLabel {
    Anchor: (Left: 456, Top: 194, Width: 1008, Height: 24);
    Text: "";
    Style: (FontSize: 13, TextColor: #cfe0f3, RenderBold: true, VerticalAlignment: Center);
  }

  Label #SpawnLabel {
    Anchor: (Left: 456, Top: 234, Width: 180, Height: 28);
    Text: "Centro (X Y Z)";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@TextField #SpawnX {
    @Anchor = (Left: 642, Top: 232, Width: 124);
    Value: "0.00";
  }

  $C.@TextField #SpawnY {
    @Anchor = (Left: 772, Top: 232, Width: 124);
    Value: "64.00";
  }

  $C.@TextField #SpawnZ {
    @Anchor = (Left: 902, Top: 232, Width: 124);
    Value: "0.00";
  }

  TextButton #SetSpawnButton {
    Anchor: (Left: 1080, Top: 232, Width: 384, Height: 34);
    Text: "Usar mi posicion actual";
    Style: $C.@SecondaryTextButtonStyle;
  }

  Label #RadiusLabel {
    Anchor: (Left: 456, Top: 286, Width: 360, Height: 28);
    Text: "Configuracion del radio de aparicion de enemigos";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  Label #RoundConfigLabel {
    Anchor: (Left: 456, Top: 398, Width: 360, Height: 28);
    Text: "Configuracion de ronda";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  Label #MinRadiusLabel {
    Anchor: (Left: 456, Top: 318, Width: 492, Height: 22);
    Text: "Radio minimo";
    Style: (FontSize: 13, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #MinRadius {
    @Anchor = (Left: 456, Top: 342, Width: 492);
    Value: 5.0;
    Min: 1.0;
    Max: 128.0;
    Step: 0.5;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #MaxRadiusLabel {
    Anchor: (Left: 972, Top: 318, Width: 492, Height: 22);
    Text: "Radio maximo";
    Style: (FontSize: 13, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #MaxRadius {
    @Anchor = (Left: 972, Top: 342, Width: 492);
    Value: 12.0;
    Min: 1.0;
    Max: 128.0;
    Step: 0.5;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #ArenaJoinRadiusLabel {
    Anchor: (Left: 1080, Top: 286, Width: 384, Height: 24);
    Text: "Radio jugadores";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #ArenaJoinRadius {
    @Anchor = (Left: 1080, Top: 314, Width: 384);
    Value: 32.0;
    Min: 4.0;
    Max: 512.0;
    Step: 1.0;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  TextButton #ReloadModButton {
    Anchor: (Left: 660, Top: 936, Width: 192, Height: 46);
    Text: "Recargar config";
    Style: $C.@TertiaryTextButtonStyle;
  }

  Label #RoundLabel {
    Anchor: (Left: 456, Top: 430, Width: 492, Height: 24);
    Text: "Cantidad de rondas";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #Rounds {
    @Anchor = (Left: 456, Top: 454, Width: 492);
    Value: 5;
    Min: 1;
    Max: 200;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #BaseEnemiesLabel {
    Anchor: (Left: 456, Top: 498, Width: 492, Height: 24);
    Text: "Cantidad base de enemigos por ronda";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #BaseEnemies {
    @Anchor = (Left: 456, Top: 522, Width: 492);
    Value: 8;
    Min: 1;
    Max: 400;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #EnemiesPerRoundLabel {
    Anchor: (Left: 972, Top: 498, Width: 492, Height: 24);
    Text: "Incremento de enemigos por ronda";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #EnemiesPerRound {
    @Anchor = (Left: 972, Top: 522, Width: 492);
    Value: 2;
    Min: 0;
    Max: 400;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #WaveDelayLabel {
    Anchor: (Left: 972, Top: 430, Width: 492, Height: 24);
    Text: "Tiempo de espera entre rondas (s)";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@SliderNumberField #WaveDelay {
    @Anchor = (Left: 972, Top: 454, Width: 492);
    Value: 8;
    Min: 0;
    Max: 300;
    Step: 1;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #PlayerMultiplierLabel {
    Anchor: (Left: 1096, Top: 232, Width: 170, Height: 24);
    Text: "Jugadores (x)";
    Style: (FontSize: 14, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  TextField #PlayerMultiplier {
    Anchor: (Left: 1096, Top: 256, Width: 148, Height: 34);
    Value: "1";
    Style: (FontSize: 14, TextColor: #e8f1ff);
    Padding: (Left: 8);
    Background: #0f1825;
  }

  Label #RoleLabel {
    Anchor: (Left: 456, Top: 232, Width: 180, Height: 28);
    Text: "Categoria de horda";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  $C.@DropdownBox #EnemyType {
    @Anchor = (Left: 642, Top: 232, Width: 620);
    Value: "undead";
  }

  Label #RoleHelpLabel {
    Anchor: (Left: 642, Top: 418, Width: 822, Height: 24);
    Text: "";
    Visible: false;
    Style: (FontSize: 12, TextColor: #9cb4d1, VerticalAlignment: Center);
  }

  Label #LanguageLabel {
    Anchor: (Left: 642, Top: 286, Width: 384, Height: 24);
    Text: "Idioma de interfaz";
    Style: (FontSize: 14, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextButton #LanguagePrevButton {
    Anchor: (Left: 642, Top: 364, Width: 38, Height: 34);
    Text: "<";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  $C.@DropdownBox #Language {
    @Anchor = (Left: 642, Top: 314, Width: 384);
    Value: "es";

    DropdownEntry {
      Value: "es";
      Text: "Espanol";
    }

    DropdownEntry {
      Value: "en";
      Text: "English";
    }

    DropdownEntry {
      Value: "pt";
      Text: "Portugues";
    }

    DropdownEntry {
      Value: "fr";
      Text: "Francais";
    }

    DropdownEntry {
      Value: "de";
      Text: "Deutsch";
    }
  }

  TextButton #LanguageNextButton {
    Anchor: (Left: 978, Top: 364, Width: 46, Height: 34);
    Text: ">";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  Label #FinalBossLabel {
    Anchor: (Left: 1276, Top: 232, Width: 120, Height: 28);
    Text: "Boss final";
    Style: (FontSize: 16, TextColor: #dde8f8, RenderBold: true, VerticalAlignment: Center);
  }

  TextButton #FinalBossPrevButton {
    Anchor: (Left: 642, Top: 456, Width: 46, Height: 34);
    Text: "<";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4b74a5, LabelStyle: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  $C.@CheckBox #FinalBossEnabled {
    Anchor: (Left: 1408, Top: 236, Width: 22, Height: 22);
    Value: false;
  }

  TextButton #FinalBossNextButton {
    Anchor: (Left: 978, Top: 456, Width: 46, Height: 34);
    Text: ">";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 18, TextColor: #e8f1ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
