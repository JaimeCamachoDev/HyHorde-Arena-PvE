  }

  Label #PlayersHeaderMode {
    Anchor: (Left: 842, Top: 332, Width: 130, Height: 24);
    Text: "Modo";
    Style: (FontSize: 12, TextColor: #a9bed9, RenderBold: true, VerticalAlignment: Center);
  }

  Group #AudiencePlayersRows {
    Anchor: (Left: 456, Top: 360, Width: 1008, Height: 492);
    LayoutMode: TopScrolling;
