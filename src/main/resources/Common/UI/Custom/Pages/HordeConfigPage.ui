    Value: 100;
    Min: 0.0;
    Max: 100.0;
    Step: 1.0;
    NumberFieldStyle: $C.@DefaultInputFieldStyle;
  }

  Label #RoundSoundHelpLabel {
    Anchor: (Left: 642, Top: 388, Width: 822, Height: 24);
