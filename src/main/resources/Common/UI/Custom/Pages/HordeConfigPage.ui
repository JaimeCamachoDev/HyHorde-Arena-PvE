$C = "../Common.ui";

@OfficialDropdownBoxStyle = DropdownBoxStyle(
  ...$C.@DefaultDropdownBoxStyle,
  LabelStyle: (
    ...$C.@DefaultDropdownBoxLabelStyle,
    FontSize: 15,
    RenderBold: true
  ),
  EntryLabelStyle: (
    ...$C.@DefaultDropdownBoxEntryLabelStyle,
    FontSize: 15
  ),
  SelectedEntryLabelStyle: (
    ...$C.@DefaultDropdownBoxEntryLabelStyle,
    FontSize: 15,
    RenderBold: true
  ),
  PanelAlign: Bottom
);

@ListRowHitboxButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../Common/Tab.png", Border: 3, Color: #8ea1bb(0.34)), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Hovered: (Background: (TexturePath: "../Common/Tab.png", Border: 3, Color: #d6e3f5(0.58)), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Pressed: (Background: (TexturePath: "../Common/Tab.png", Border: 3, Color: #f3f8ff(0.76)), LabelStyle: (FontSize: 1, TextColor: #000000(0)))
);

@ArenaListRowHitboxStyle = TextButtonStyle(
  Default: (Background: #000000(0), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Hovered: (Background: #ffffff(0.08), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Pressed: (Background: #ffffff(0.14), LabelStyle: (FontSize: 1, TextColor: #000000(0)))
);

@TrashDeleteButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../Icons/AssetNotifications/Trash.png", Color: #ffd7d1(0.84)), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Hovered: (Background: (TexturePath: "../Icons/AssetNotifications/Trash.png", Color: #fff4f1), LabelStyle: (FontSize: 1, TextColor: #000000(0))),
  Pressed: (Background: (TexturePath: "../Icons/AssetNotifications/Trash.png", Color: #ffbfb6(0.92)), LabelStyle: (FontSize: 1, TextColor: #000000(0)))
);

@ArenaNameLabelStyle = (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #ecf4ff, RenderBold: true, VerticalAlignment: Center);
@ArenaCoordsLabelStyle = (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #b8cbe5, VerticalAlignment: Center);
Group {
  Anchor: (Full: 0);

  SceneBlur {
    Anchor: (Full: 0);
  }

  $C.@PageOverlay #Overlay {
    Anchor: (Full: 0);
  }

  TabNavigation #CategoryTabs {
    Anchor: (Left: 432, Top: 28, Width: 1056, Height: 66);
    Style: $C.@TopTabsStyle;
    SelectedTab: "general";

    TabButton #TabGeneralButton {
      Id: "general";
      Icon: "../Icons/ItemCategories/Builder Tools.png";
      Text: "";
      TooltipText: "General";
    }

    TabButton #TabPlayersButton {
      Id: "players";
      Icon: "../Icons/ItemCategories/Items-Armor.png";
      Text: "";
      TooltipText: "Jugadores";
    }

    TabButton #TabArenasButton {
      Id: "arenas";
      Icon: "../Icons/ItemCategories/Build-Roofs.png";
      Text: "";
      TooltipText: "Arenas";
    }

    TabButton #TabEnemiesButton {
      Id: "enemies";
      Icon: "../Icons/ItemCategories/Items-Weapons.png";
      Text: "";
      TooltipText: "Enemigos";
    }

    TabButton #TabHordeButton {
      Id: "horde";
      Icon: "../Icons/ItemCategories/Items-Traps.png";
      Text: "";
      TooltipText: "Horda";
    }

    TabButton #TabBossesButton {
      Id: "bosses";
      Icon: "../Icons/ItemCategories/Natural-Fire.png";
      Text: "";
      TooltipText: "Bosses";
    }

    TabButton #TabRewardsButton {
      Id: "rewards";
      Icon: "../Icons/ItemCategories/Container.png";
      Text: "";
      TooltipText: "Recompensas";
    }

    TabButton #TabSoundsButton {
      Id: "sounds";
      Icon: "../Icons/ItemCategories/Build-Lights.png";
      Text: "";
      TooltipText: "Sonidos";
    }

    TabButton #TabHelpButton {
      Id: "help";
      Icon: "../Icons/ItemCategories/Misc.png";
      Text: "";
      TooltipText: "Ayuda";
    }
  }

